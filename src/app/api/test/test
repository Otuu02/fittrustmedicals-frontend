import { NextResponse } from 'next/server';

export async function GET() {
  return NextResponse.json({
    AWS_REGION: process.env.AWS_REGION || 'NOT FOUND',
    AWS_S3_BUCKET_NAME: process.env.AWS_S3_BUCKET_NAME || 'NOT FOUND',
    AWS_ACCESS_KEY_ID: process.env.AWS_ACCESS_KEY_ID ? 'EXISTS' : 'NOT FOUND',
    AWS_SECRET_ACCESS_KEY: process.env.AWS_SECRET_ACCESS_KEY ? 'EXISTS' : 'NOT FOUND',
  });
}